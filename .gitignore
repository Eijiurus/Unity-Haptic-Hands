*.opendb
*.VC.db

# OS
.DS_Store
Thumbs.db

# Python (SensorBridge.py / HapticBridge.py 等本地脚本)
__pycache__/
*.py[cod]
*.pyo

# Gradle (Android builds)
ExportedObj/
*.apk
*.aab
*.unitypackage
*.unitypackage.meta

# Builds
*.exe
*.app
